### Local .env for copying into Render (DO NOT commit secrets to remote)
SPRING_DATASOURCE_DRIVER=org.mariadb.jdbc.Driver

# Database (you can also set SPRING_DATASOURCE_URL instead of DB_HOST/DB_NAME)
# DESCOMENTADO PARA PRODUÇÃO: Usar MariaDB
SPRING_DATASOURCE_URL=jdbc:mariadb://SEU_IP_AQUI:3306/portfolio
SPRING_DATASOURCE_USERNAME=seu_usuario_db
SPRING_DATASOURCE_PASSWORD='sua_senha_db_aqui'
DB_HOST=SEU_IP_AQUI
DB_NAME=portfolio

# MinIO / S3
MINIO_URL=http://s3.seu-dominio.com.br
MINIO_ACCESS_KEY=sua_access_key_aqui
MINIO_SECRET_KEY='sua_secret_key_aqui'
MINIO_BUCKET_NAME=portfolio-image

# Admin credentials for /admin (rotate for production)
APP_ADMIN_USERNAME=admin
APP_ADMIN_PASSWORD=sua_senha_admin_aqui

# App / JVM
PORT=8080
SPRING_PROFILES_ACTIVE=prod
SPRING_JPA_HIBERNATE_DDL_AUTO=validate

# Redis Cache
REDIS_HOST=SEU_IP_REDIS_AQUI
REDIS_PORT=6379
REDIS_PASSWORD='sua_senha_redis_aqui'

# Integração Telegram
TELEGRAM_BOT_TOKEN=seu_token_do_bot_aqui
TELEGRAM_CHAT_ID=seu_chat_id_aqui